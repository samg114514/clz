---
---

<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CLZ - Software Marketplace</title>
</head>

<body class="bg-black text-white">

<header class="border-b border-zinc-800">
  <div class="max-w-7xl mx-auto flex justify-between items-center py-5 px-6">
    <h1 class="text-2xl font-bold">CLZ</h1>

    <div class="space-x-4">
      <button class="px-4 py-2">Login</button>
      <button class="bg-white text-black px-4 py-2 rounded-lg">
        Register
      </button>
    </div>
  </div>
</header>

<section class="max-w-7xl mx-auto px-6 py-28 text-center">

  <h1 class="text-6xl font-bold mb-6">
    Premium Software & Scripts
  </h1>

  <p class="text-zinc-400 text-xl mb-10">
    Fast Delivery · Secure Payment · Instant Access
  </p>

  <button class="bg-white text-black px-8 py-4 rounded-xl font-bold">
    Explore Products
  </button>

</section>

<section class="max-w-7xl mx-auto px-6 py-20">

  <h2 class="text-4xl font-bold text-center mb-12">
    Featured Products
  </h2>

  <div class="grid md:grid-cols-3 gap-8">

    <div class="bg-zinc-900 p-6 rounded-2xl">
      <h3 class="text-xl font-bold mb-2">
        Script Pro
      </h3>

      <p class="text-zinc-400 mb-4">
        Powerful automation solution.
      </p>

      <p class="text-3xl font-bold">
        $19
      </p>
    </div>

    <div class="bg-zinc-900 p-6 rounded-2xl">
      <h3 class="text-xl font-bold mb-2">
        Tool Suite
      </h3>

      <p class="text-zinc-400 mb-4">
        Complete toolkit package.
      </p>

      <p class="text-3xl font-bold">
        $39
      </p>
    </div>

    <div class="bg-zinc-900 p-6 rounded-2xl">
      <h3 class="text-xl font-bold mb-2">
        Premium Access
      </h3>

      <p class="text-zinc-400 mb-4">
        Unlimited downloads.
      </p>

      <p class="text-3xl font-bold">
        $99
      </p>
    </div>

  </div>

</section>

<section class="bg-zinc-950 py-20">

  <div class="max-w-6xl mx-auto px-6">

    <h2 class="text-4xl font-bold text-center mb-12">
      Why Choose CLZ
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

      <div>
        <h3 class="font-bold mb-2">Instant Delivery</h3>
        <p class="text-zinc-400">
          Receive your product immediately after payment.
        </p>
      </div>

      <div>
        <h3 class="font-bold mb-2">Secure Payments</h3>
        <p class="text-zinc-400">
          Support EasyPay and CodePay.
        </p>
      </div>

      <div>
        <h3 class="font-bold mb-2">24/7 Support</h3>
        <p class="text-zinc-400">
          Fast and reliable customer service.
        </p>
      </div>

    </div>

  </div>

</section>

<footer class="border-t border-zinc-800 py-10 text-center text-zinc-500">
  © 2025 CLZ. All rights reserved.
</footer>

</body>
</html>